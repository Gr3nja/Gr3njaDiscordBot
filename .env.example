# Discord Developer Portal で発行した Bot トークン
DISCORD_TOKEN=

# テキストコマンドの接頭辞 例: !help
BOT_PREFIX=!

# イベント表示やデイリー報酬判定に使う基準タイムゾーン
BOT_TIMEZONE=Asia/Tokyo

# SQLite データベースの保存先パス
DATABASE_PATH=data/bot.db

# Lavalink の接続先ホスト
LAVALINK_HOST=

# Lavalink の接続先ポート
LAVALINK_PORT=2333

# Lavalink の接続パスワード
LAVALINK_PASSWORD=

# Lavalink を HTTPS / WSS で使う場合は true
LAVALINK_SECURE=false

# キーワード検索時の既定ソース (ytsearch / ytmsearch / scsearch など)
MUSIC_DEFAULT_SEARCH=ytsearch

# 再生音量 (0-1000)
MUSIC_DEFAULT_VOLUME=75

# キューが空になってから自動切断するまでの秒数
MUSIC_IDLE_DISCONNECT_SECONDS=300

# AI チャット API のベース URL (OpenAI 互換 API を想定)
AI_BASE_URL=

# AI チャット API キー (LM Studio など不要な場合は空で可)
AI_API_KEY=

# サーバー既定の AI モデルキー (gemini / gpt-oss:20b / gemma3:27b)
AI_DEFAULT_MODEL=gemini

# 各モデルキーに対応する実APIモデル名
AI_MODEL_GEMINI=gemini
AI_MODEL_GPT_OSS_20B=gpt-oss:20b
AI_MODEL_GEMMA3_27B=gemma3:27b

# AI に毎回与えるシステムプロンプト
AI_SYSTEM_PROMPT=あなたはDiscordサーバーで動作するAIアシスタントです。回答は日本語で簡潔かつ親しみやすくしてください。

# 会話履歴として保持するターン数
AI_MAX_HISTORY_TURNS=8

# AI 応答のタイムアウト秒数
AI_REQUEST_TIMEOUT_SECONDS=60

# 1 回の AI 応答として送信する最大文字数
AI_MAX_RESPONSE_CHARS=4000

# 自己紹介チャンネルで自動付与する既定のリアクション
INTRO_REACTION_EMOJI=🤝

# 所持金表示やショップで使うサーバー通貨の既定名
DEFAULT_CURRENCY_NAME=グレコイン

# デイリー報酬の付与額
DAILY_REWARD=150

# 通常メッセージ送信時に付与する報酬額
MESSAGE_REWARD=5

# メッセージ報酬を再獲得できるまでのクールダウン秒数
MESSAGE_REWARD_COOLDOWN=60

# しりとりで有効な単語を出したときの報酬額
SHIRITORI_REWARD=10

# イベント作成時に報酬省略された場合の既定値
EVENT_DEFAULT_REWARD=100

# VC の発狂検知しきい値 値が大きいほど反応しにくい
VOICE_SCREAM_THRESHOLD=9000

# 発狂検知前にさかのぼって保持する音声秒数
VOICE_PRE_BUFFER_SECONDS=3.0

# 発狂検知後に追加で保持する音声秒数
VOICE_POST_BUFFER_SECONDS=2.5

# 同一ユーザーの次回クリップ作成までのクールダウン秒数
VOICE_CLIP_COOLDOWN_SECONDS=20.0

# Discord へ送信するために必要な最小クリップ秒数
VOICE_MIN_CLIP_SECONDS=1.5
